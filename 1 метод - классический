#include <Arduino.h>

// --- КОНФИГУРАЦИЯ ---
const uint8_t PIN_RED = 13;
const uint8_t PIN_YELLOW = 12;
const uint8_t PIN_GREEN = 11;
const uint8_t PIN_BTN = 2;

// Тайминги (мс)
const unsigned long T_GREEN = 10000;
const unsigned long T_YELLOW = 3000;
const unsigned long T_RED_NORMAL = 10000;
const unsigned long T_RED_PED = 15000;      // +5 сек для пешехода
const unsigned long T_BLINK = 500;          // Период мигания
const unsigned long DEBOUNCE_DELAY = 50;
const unsigned long LONG_PRESS_TIME = 2000; // Порог длинного нажатия

// --- СОСТОЯНИЯ И СОБЫТИЯ ---
enum State { S_GREEN, S_YELLOW, S_RED, S_WARNING };
// События обрабатываются внутри логики через флаги

// --- ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ ---
State currentState = S_GREEN;
unsigned long stateStartMillis = 0;
unsigned long stateDuration = 0;

bool pedRequest = false;       // Флаг запроса пешехода
bool warningMode = false;      // Флаг режима WARNING (Авария/Ночь)

// Переменные кнопки
int lastBtnState = HIGH;
int currBtnState = HIGH;
unsigned long lastDebounceTime = 0;
unsigned long pressStartTime = 0;

// --- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ---

void setOutputs(State s) {
  digitalWrite(PIN_RED, LOW);
  digitalWrite(PIN_YELLOW, LOW);
  digitalWrite(PIN_GREEN, LOW);

  if (s == S_GREEN) digitalWrite(PIN_GREEN, HIGH);
  else if (s == S_YELLOW) digitalWrite(PIN_YELLOW, HIGH);
  else if (s == S_RED) digitalWrite(PIN_RED, HIGH);
  // S_WARNING управляется вручную (мигание)
}

void logTransition(State from, State to, const char* reason) {
  const char* names[] = {"GREEN", "YELLOW", "RED", "WARNING"};
  Serial.print(millis());
  Serial.print(" | ");
  Serial.print(names[from]);
  Serial.print(" -> ");
  Serial.print(names[to]);
  Serial.print(" | Reason: ");
  Serial.println(reason);
}

void goToState(State s, unsigned long dur) {
  State prev = currentState;
  currentState = s;
  stateDuration = dur;
  stateStartMillis = millis();
  
  if (s != S_WARNING) {
    setOutputs(s);
  }
  
  logTransition(prev, s, "Transition");
}

void readInputs() {
  int reading = digitalRead(PIN_BTN);
  
  if (reading != lastBtnState) {
    lastDebounceTime = millis();
  }

  if ((millis() - lastDebounceTime) > DEBOUNCE_DELAY) {
    if (reading != currBtnState) {
      currBtnState = reading;
      
      if (currBtnState == LOW) { // Нажали
        pressStartTime = millis();
      } else { // Отпустили
        unsigned long duration = millis() - pressStartTime;
        
        if (duration >= LONG_PRESS_TIME) {
          // Длинное нажатие: Toggle WARNING mode
          warningMode = !warningMode;
          Serial.print(">>> MODE TOGGLE: ");
          Serial.println(warningMode ? "WARNING ON" : "WARNING OFF");
        } else if (duration > 50) { 
          // Короткое нажатие: Запрос пешехода
          pedRequest = true;
          Serial.println(">>> PED REQUEST SET");
        }
      }
    }
  }
  lastBtnState = reading;
}


void setup() {
  pinMode(PIN_RED, OUTPUT);
  pinMode(PIN_YELLOW, OUTPUT);
  pinMode(PIN_GREEN, OUTPUT);
  pinMode(PIN_BTN, INPUT_PULLUP);
  
  Serial.begin(9600);
  while(!Serial); // Ждем порт
  
  Serial.println("--- FSM CLASSICAL METHOD STARTED ---");
  goToState(S_GREEN, T_GREEN);
}

void loop() {
  // 1. Читаем входы (обновляем флаги pedRequest, warningMode)
  readInputs();

  // 2. Приоритет: Режим WARNING (Авария/Ночь)
  if (warningMode) {
    if (currentState != S_WARNING) {
      goToState(S_WARNING, T_BLINK);
    } else {
      // Логика мигания внутри состояния WARNING
      if (millis() - stateStartMillis >= stateDuration) {
        digitalWrite(PIN_YELLOW, !digitalRead(PIN_YELLOW)); // Toggle LED
        stateStartMillis = millis(); // Сброс таймера мигания
      }
    }
    return; // Выход из loop, игнорируем остальную логику пока активен WARNING
  }

  // Если были в WARNING и режимвыключили -> сброс в начало цикла (упрощено по ТЗ)
  if (currentState == S_WARNING && !warningMode) {
    goToState(S_GREEN, T_GREEN);
    return;
  }

  // 3. Проверка истечения таймера текущего состояния
  bool timerExpired = (millis() - stateStartMillis >= stateDuration);

  // 4. Классический Switch-Case
  switch (currentState) {
    case S_GREEN:
      if (timerExpired) {
        // Переход в желтый всегда происходит по таймеру
        // Флаг пешехода будет проверен в следующем состоянии (Yellow) или здесь для планирования
        goToState(S_YELLOW, T_YELLOW);
      }
      break;

    case S_YELLOW:
      if (timerExpired) {
        if (pedRequest) {
          pedRequest = false; // Сбрасываем флаг после использования
          Serial.println(">>> Pedestrian Active: Extending Red");
          goToState(S_RED, T_RED_PED); // Удлиненный красный
        } else {
          goToState(S_RED, T_RED_NORMAL);
        }
      }
      break;

    case S_RED:
      if (timerExpired) {
        goToState(S_GREEN, T_GREEN);
      }
      break;

    case S_WARNING:
      break;
  }
}
